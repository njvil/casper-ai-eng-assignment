-shared-star-rating__icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ugc-shared-icon-star"></use></svg></span><span class="mm-recipes-ugc-shared-star-rating__star"><svg class="ugc-shared-icon-star mm-recipes-ugc-shared-star-rating__icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ugc-shared-icon-star"></use></svg></span></div><!-- Feedback Publish Date --><span class="mm-recipes-ugc-shared-card-meta__date">05/31/2012</span></div><!--v-if--><div class="mm-recipes-ugc-shared-item-card__body-container"><div class="mm-recipes-ugc-shared-item-card__body mm-recipes-ugc-shared-item-card__body--show-read-more"><!--v-if--><div class="mm-recipes-ugc-shared-item-card__text-wrapper"><div class="mm-recipes-ugc-shared-item-card__text">I did as another rater suggested: skipped dissolving baking soda in water and increased the vanilla to 1 tablespoon, and changed the sugar to 1/2 cup white and 1.5 cups brown. Baked for 12 minutes at 350 and OMG they taste like they came from a bakery! I have never made better cookies.

I do not own a mixer and therefore make everything by hand, so this recipe seemed daunting at first... but with a little elbow grease, it was a snap. <!--v-if--></div><button data-click-tracked="false" class="mm-recipes-ugc-shared-item-card__read-more"> Read More </button></div></div><div class="mm-recipes-ugc-shared-card-toolbar mm-recipes-ugc-shared-item-card__toolbar"><div class="mm-recipes-ugc-shared-card-toolbar__buttons"><button class="mm-recipes-ugc-shared-helpful-button" data-feedback-id="1446a5803f060873093e0232a84bbcef38a3d754_6649624" data-click-tracked="false" helpfulbtneventaction=""><svg class="ugc-shared-icon-helpful-fill"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ugc-shared-icon-helpful-fill"></use></svg><svg class="ugc-shared-icon-helpful-outline"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ugc-shared-icon-helpful-outline"></use></svg> 12</button><button class="mm-recipes-ugc-shared-response-button" data-click-tracked="false"><svg class="ugc-shared-icon-reply"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ugc-shared-icon-reply"></use></svg> Reply</button><!--v-if--></div><!--v-if--></div></div></div><!--v-if--></div><div data-feedback-id="2c59f691eb626efeba61c95038142c44e2beff0a_6649624" data-response-count="0" class="mm-recipes-ugc-shared-item-card mm-recipes-ugc-shared-item-card--review mm-recipes-ugc-shared-item-card--review-2c59f691eb626efeba61c95038142c44e2beff0a_6649624 mm-recipes-ugc-threaded-carousel__card"><div class="mm-recipes-ugc-shared-item-card__content"><!--v-if--><!--v-if--><div class="mm-recipes-ugc-shared-card-byline"><!-- Don't show user avatar in read only mode --><span class="mm-recipes-ugc-shared-card-byline__avatar-wrapper"><svg class="ugc-shared-icon-avatar-5 ugc-threaded-icon-avatar-5 mm-recipes-ugc-shared-card-byline__avatar-icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#ugc-shared-icon-avatar-5"></use></svg></span><span class="mm-recipes-ugc-shared-card